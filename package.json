{
  "name": "iobroker.parcelapp",
  "version": "0.1.2",
  "description": "Track your packages from 300+ carriers via parcel.app",
  "author": {
    "name": "krobi",
    "email": "krobi@power-dreams.com"
  },
  "homepage": "https://github.com/krobipd/ioBroker.parcelapp",
  "license": "MIT",
  "keywords": [
    "ioBroker",
    "parcel",
    "tracking",
    "delivery",
    "package",
    "shipment"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/krobipd/ioBroker.parcelapp"
  },
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  },
  "dependencies": {
    "@iobroker/adapter-core": "^3.3.2"
  },
  "devDependencies": {
    "@alcalzone/release-script": "^5.1.1",
    "@alcalzone/release-script-plugin-iobroker": "^5.1.2",
    "@alcalzone/release-script-plugin-license": "^5.1.1",
    "@alcalzone/release-script-plugin-manual-review": "^5.1.1",
    "@iobroker/adapter-dev": "^1.5.0",
    "@iobroker/build-tools": "^3.0.1",
    "@iobroker/eslint-config": "^2.2.0",
    "@iobroker/testing": "^5.2.2",
    "@types/node": "^25.5.0",
    "eslint": "^10.1.0",
    "source-map-support": "^0.5.21",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  },
  "files": [
    "admin",
    "build",
    "io-package.json",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "prepare": "test -d build || npm run build",
    "prebuild": "rm -rf ./build",
    "build:ts": "tsc -p tsconfig.build.json",
    "build": "npm run build:ts",
    "build:test": "tsc -p tsconfig.test.json",
    "watch": "tsc -p tsconfig.build.json --watch",
    "check": "tsc -p tsconfig.build.json --noEmit",
    "test:package": "npm run build:test && mocha --exit \"build/test/testPackageFiles.js\"",
    "test:integration": "npm run build:test && mocha --exit \"build/test/**/*.js\"",
    "test": "npm run build:test && mocha --exit \"build/test/**/*.js\"",
    "test:ci": "npm run build:test && mocha --exit --reporter spec \"build/test/**/*.js\"",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "release": "release-script"
  },
  "bugs": {
    "url": "https://github.com/krobipd/ioBroker.parcelapp/issues"
  },
  "main": "build/main.js"
}
