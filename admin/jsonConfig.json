{
  "i18n": true,
  "type": "panel",
  "items": {
    "connectionHeader": {
      "type": "header",
      "text": "header_connection",
      "size": 4
    },
    "apiKeyInfo": {
      "type": "staticText",
      "text": "apiKeyInfo",
      "xs": 12,
      "sm": 12,
      "md": 12,
      "lg": 12,
      "xl": 12,
      "style": {
        "fontSize": 14,
        "color": "#666",
        "marginBottom": 16
      }
    },
    "apiKey": {
      "type": "password",
      "label": "label_apiKey",
      "xs": 12,
      "sm": 12,
      "md": 8,
      "lg": 8,
      "xl": 8
    },
    "checkConnection": {
      "newLine": true,
      "type": "sendTo",
      "label": "btn_checkConnection",
      "command": "checkConnection",
      "jsonData": "{\"apiKey\": \"${data.apiKey}\"}",
      "result": {
        "okText": "msg_connectionOk",
        "errorText": "msg_connectionFailed"
      },
      "xs": 12,
      "sm": 12,
      "md": 4,
      "lg": 4,
      "xl": 4
    },
    "pollingHeader": {
      "newLine": true,
      "type": "header",
      "text": "header_polling",
      "size": 5
    },
    "pollInterval": {
      "type": "number",
      "label": "label_pollInterval",
      "tooltip": "tooltip_pollInterval",
      "min": 5,
      "max": 60,
      "default": 10,
      "xs": 12,
      "sm": 12,
      "md": 6,
      "lg": 6,
      "xl": 6
    },
    "deliveryHeader": {
      "newLine": true,
      "type": "header",
      "text": "header_delivery",
      "size": 5
    },
    "autoRemoveDelivered": {
      "type": "checkbox",
      "label": "label_autoRemoveDelivered",
      "tooltip": "tooltip_autoRemoveDelivered",
      "default": true,
      "xs": 12,
      "sm": 12,
      "md": 12,
      "lg": 12,
      "xl": 12
    },
    "_supportHeader": {
      "newLine": true,
      "type": "header",
      "text": "supportHeader",
      "size": 5
    },
    "_aboutInfo": {
      "type": "staticText",
      "text": "aboutInfo",
      "xs": 12,
      "sm": 12,
      "md": 12,
      "lg": 12,
      "xl": 12,
      "style": {
        "fontSize": 14,
        "marginBottom": 16
      }
    },
    "_kofiLink": {
      "type": "staticLink",
      "href": "https://ko-fi.com/krobipd",
      "label": "donateKofi",
      "button": true,
      "variant": "outlined",
      "color": "primary",
      "xs": 12,
      "sm": 6,
      "md": 4,
      "lg": 4,
      "xl": 4
    },
    "_paypalLink": {
      "type": "staticLink",
      "href": "https://paypal.me/krobipd",
      "label": "donatePaypal",
      "button": true,
      "variant": "outlined",
      "color": "primary",
      "xs": 12,
      "sm": 6,
      "md": 4,
      "lg": 4,
      "xl": 4
    }
  }
}
